---
import { Image } from "astro:assets";
import "../styles/main.css";
import SiteNav from "../components/SiteNav.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../utils/url";

interface Props {
  title: string;
  code: string;
  details: { label: string; value: string }[];
  gallery: { image: ImageMetadata; alt: string; caption?: string }[];
  nextProject?: { slug: string; code: string };
}

const { title, code, details, gallery, nextProject } = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Francesca Caslini</title>
    <meta name="description" content={`${title}: ${details.map((d) => `${d.label} ${d.value}`).join(", ")}.`} />
  </head>
  <body>
    <main>
      <div class="project container">
        <aside class="project__intro">
          <p class="project__code">{code}</p>
          <h1 class="project__title">{title}</h1>
          <dl class="project__details">
            {details.map((detail) => (
              <div class="project__detail-row">
                <dt>{detail.label}</dt>
                <dd>{detail.value}</dd>
              </div>
            ))}
          </dl>
          <div class="project__description">
            <slot />
          </div>
        </aside>

        <div class="project__gallery">
          {gallery.map((item) => (
            <figure class="project__gallery-item">
              <Image src={item.image} alt={item.alt} width={960} />
              {item.caption && <figcaption>{item.caption}</figcaption>}
            </figure>
          ))}

          {nextProject && (
            <a class="project__next" href={withBase(`/projects/${nextProject.slug}/`)}>
              Go to next project — {nextProject.code}
            </a>
          )}
        </div>

        <SiteNav class="project__nav" />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .project {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-7) var(--space-3);
  }

  .project__code {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .project__title {
    margin-top: var(--space-2);
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .project__details {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-grey);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .project__detail-row {
    display: flex;
    gap: var(--space-1);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    color: var(--color-black);
  }

  .project__detail-row dt {
    min-width: 7rem;
  }

  .project__detail-row dd {
    margin: 0;
  }

  .project__detail-row dd::before {
    content: "-";
    margin-right: var(--space-1);
  }

  .project__description {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-grey);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-base);
    color: var(--color-black);
  }

  .project__description :global(blockquote) {
    margin: 0;
    padding-left: var(--space-3);
    border-left: 2px solid var(--color-grey);
    font-style: italic;
  }

  .project__description :global(blockquote p) {
    margin: 0;
  }

  .project__gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .project__gallery-item img {
    width: 100%;
    height: auto;
    border: 1px solid rgba(0, 0, 0, 0.2);
  }

  .project__gallery-item figcaption {
    margin-top: var(--space-1);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    text-align: right;
  }

  .project__next {
    margin-top: var(--space-5);
    align-self: flex-start;
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .project__next:hover,
  .project__next:focus-visible {
    color: var(--color-blue);
  }

  .project__next:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  @media (min-width: 64rem) {
    .project {
      grid-template-columns: 1fr 2fr 1fr;
      align-items: start;
    }

    .project__intro {
      position: sticky;
      top: var(--space-3);
    }
  }
</style>
