---
import "../styles/main.css";
import HeroImage from "../components/HeroImage.astro";
import Header from "../components/Header.astro";
import ProjectList from "../components/ProjectList.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Francesca Caslini — Architecture Portfolio</title>
    <meta
      name="description"
      content="Portfolio di architettura di Francesca Caslini, MSc Arch. PoliMi. Progetti professionali e universitari 2018-2024."
    />
  </head>
  <body>
    <div class="page-row container">
      <HeroImage />
      <main class="page-row__content">
        <Header />
        <ProjectList />
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-row {
    display: flex;
    flex-direction: column;
  }

  .page-row__content {
    min-width: 0;
  }

  @media (min-width: 64rem) {
    .page-row {
      display: grid;
      grid-template-columns: 1fr 2fr 1fr;
      align-items: start;
    }

    .page-row__content {
      grid-column: 2;
    }
  }
</style>
