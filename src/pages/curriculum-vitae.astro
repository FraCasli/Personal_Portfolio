];

const skills = [
  "AutoCAD   -   advanced level",
  "ArchiCAD   -   advanced level",
  "Rhinoceros and Grasshopper   -   intermediate level",
  "3ds Max and Corona   -   intermediate level",
  "Adobe Creative Suite (Acrobat, Photoshop, Illustrator, Indesign)   -   advanced level",
  "Figma   -   advanced level",
  "Microsoft Office Package (Word, Excel)   -   advanced level",
  "Experience in model making with various techniques (timber, cardboard, styrofoam, concrete, plaster, etc.)   -   advanced level",
];

const languages = ["Italian   -   mother tongue", "English   -   TOEIC"];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Curriculum vitae — Francesca Caslini</title>
    <meta name="description" content="Curriculum vitae di Francesca Caslini, MSc Arch. PoliMi: formazione, esperienze professionali e didattiche, ricerca, tesi, competenze." />
  </head>
  <body>
    <TopBar href={withBase("/")} />
    <main>
      <div class="cv container">
        <aside class="cv__profile">
          <Image class="cv__photo" src={cvPortrait} alt="Ritratto di Francesca Caslini" width={240} height={290} />
          <div class="cv__identity">
            <p class="cv__name">Francesca Caslini</p>
            <p class="cv__role">MSc Arch. PoliMi</p>
          </div>
          <div class="cv__contact">
            <p>+39 3337438860</p>
            <p><a href="mailto:francesca.caslini@mail.polimi.it">francesca.caslini@mail.polimi.it</a></p>
            <p>19 Aprile 1997</p>
            <p>Via P. Nenni 9, 24020 Scanzorosciate BG</p>
          </div>
          <img
            class="cv__signature"
            src={withBase("/assets/images/signature.png")}
            alt="Firma di Francesca Caslini"
            width="870"
            height="286"
          />
        </aside>

        <div class="cv__content">
          {sections.map((section) => (
            <section class="cv-section">
              <h2 class="cv-section__title">{section.title}</h2>
              <ul class="cv-entries">
                {section.entries.map((entry) => (
                  <li class="cv-entry">
                    <p class="cv-entry__date">{entry.date}</p>
                    <div class="cv-entry__body">
                      {entry.role && <p class="cv-entry__role">{entry.role}</p>}
                      {entry.lines.map((line) => (
                        <p>{line}</p>
                      ))}
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          ))}

          <section class="cv-section">
            <h2 class="cv-section__title">Skills</h2>
            <ul class="cv-list">
              {skills.map((skill) => (
                <li>{skill}</li>
              ))}
            </ul>
          </section>

          <section class="cv-section">
            <h2 class="cv-section__title">Languages</h2>
            <ul class="cv-list">
              {languages.map((language) => (
                <li>{language}</li>
              ))}
            </ul>
          </section>

          <p class="cv-consent">
            According to law 679/2016 of the Regulation of the European Parliament of 27th April 2016, I hereby express my consent to
            process and use my data provided in this CV and application for recruiting purposes.
            <br />
            Thank you for your attention.
          </p>
        </div>

        <SiteNav class="cv__nav" />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .cv {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-7) var(--space-3);
  }

  .cv__profile {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cv__photo {
    width: 100%;
    max-width: 15rem;
    height: auto;
    aspect-ratio: 240 / 290;
    object-fit: cover;
  }

  .cv__name {
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .cv__role,
  .cv__contact p {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .cv__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cv__contact a:hover {
    color: var(--color-blue);
  }

  .cv__signature {
    width: 8rem;
    height: auto;
  }

  .cv__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cv-section__title {
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-grey);
  }

  .cv-entries {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cv-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-grey);
  }

  .cv-entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .cv-entry__date,
  .cv-entry__body p {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .cv-entry__date {
    color: var(--color-blue);
  }

  .cv-entry__role {
    font-weight: var(--font-weight-book);
  }

  .cv-entry__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cv-list {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .cv-consent {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    line-height: var(--line-height-base);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-grey);
  }

  @media (min-width: 40rem) {
    .cv-entry {
      flex-direction: row;
      gap: var(--space-4);
    }

    .cv-entry__date {
      min-width: 10rem;
      flex-shrink: 0;
    }
  }

  @media (min-width: 64rem) {
    .cv {
      grid-template-columns: 1fr 2fr 1fr;
      align-items: start;
    }

    .cv__profile {
      position: sticky;
      top: var(--space-3);
    }

    .cv__nav {
      position: sticky;
      top: var(--space-3);
    }
  }
</style>
