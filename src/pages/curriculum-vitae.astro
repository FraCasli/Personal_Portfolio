---
import { Image } from "astro:assets";
import "../styles/main.css";
import SiteNav from "../components/SiteNav.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../utils/url";
import cvPortrait from "../assets/images/cv-portrait.jpg";

interface CvBullet {
  label?: string;
  text: string;
}

interface CvEntry {
  date: string;
  location?: string;
  role: string;
  company?: string;
  intro?: string;
  note?: string;
  bullets?: CvBullet[];
}

interface CvSection {
  title: string;
  entries: CvEntry[];
}

const sections: CvSection[] = [
  {
    title: "Professional experience",
    entries: [
      {
        location: "Soglio GR, CH",
        date: "08/24 - ongoing",
        role: "Architectural Project Coordinator",
        company: "at Alder Clavuot Nunzi Architekten GmbH ETH SIA",
        intro:
          "High-end alpine hospitality and residential renovation projects in Engadin and Bregaglia, with growing responsibilities from design development to tendering, execution and construction phase coordination.",
        bullets: [
          {
            label: "Design development",
            text: "translated design intent into refined architectural layouts and technical packages, ensuring consistency between spatial concept, material quality, execution details and site constraints. Evolving project concepts into coherent, buildable proposals up to building permit stage.",
          },
          {
            label: "Technical documentation, tendering and cost control",
            text: "produced executive drawings, construction details, tender packages, BOQs, RFQs and quote comparisons, aligning scope, technical requirements, supplier offers and cost-related inputs with contractors, suppliers and vendors.",
          },
          {
            label: "Construction coordination and detail control",
            text: "supported construction activities by checking works on site, including custom joinery elements produced together with specialist cabinetmakers and metalworkers, reviewing details, materials and workmanship with contractors and suppliers, and assisting in resolving issues to maintain the intended quality.",
          },
          {
            label: "Time-sensitive delivery",
            text: "used to working with tight deadlines to ensure project completion ahead of seasonal reopening.",
          },
        ],
      },
      {
        location: "Soglio GR, CH",
        date: "01/23 - 03/24",
        role: "Architectural designer",
        company: "at Ruinelli Associati Architetti",
        bullets: [
          {
            label: "Concept and design development",
            text: "contributed to architectural concepts, design development and contextual strategies for alpine residential, civic and adaptive reuse projects.",
          },
          {
            label: "Technical documentation and detailing",
            text: "developed drawings, construction details and project documentation with strong focus on materials, precision and execution quality.",
          },
          {
            label: "Material sensitivity",
            text: "developed a strong design culture based on material precision, contextual sensitivity and high-quality detailing, transferable to luxury brand environments where aesthetics and execution standards must remain consistent.",
          },
        ],
      },
      {
        location: "Milan MI, IT",
        date: "09/21 - 04/24",
        role: "Teaching assistant",
        company: "at Politecnico di Milano",
        intro:
          "Supported teaching activities for Architectural Design and Fundamentals of Representation, assisting with student reviews, drawing feedback, design development and course coordination.",
      },
      {
        location: "Milan MI, IT",
        date: "2 months each",
        role: "Earlier Architectural Experiences - Internships",
        company: "at Officina Magisafi, Studio A/C and 02 Arch",
      },
    ],
  },
  {
    title: "Education and training",
    entries: [
      {
        date: "12/20 - 02/23",
        role: "ASP - Alta Scuola Politecnica | Politecnico di Milano e Politecnico di Torino",
        note: "Multidisciplinary international honour program",
      },
      {
        date: "09/20 - 05/23",
        role: "Master's Degree in Architecture - Built Environment – Interiors | Politecnico di Milano",
        note: "110/110 cum laude   Average grade: 29.37 / 30",
      },
      {
        date: "09/21 - 02/22",
        role: "Erasmus+ Programme | Manchester School of Architecture",
      },
      {
        date: "09/17 - 09/20",
        role: "Bachelor's degree in Architectural design | Politecnico di Milano",
        note: "110/110 cum laude   Average grade: 29.1 / 30",
      },
    ],
  },
];

const skills: CvBullet[] = [
  {
    label: "Design and architecture",
    text: "spatial planning, high-end interiors, material research, design intent translation, technical guidelines, detail validation.",
  },
  {
    label: "Design and Technical Documentation",
    text: "executive drawings, technical detailing, renovation projects, hospitality projects, adaptive reuse, Swiss alpine construction context.",
  },
  {
    label: "Construction Coordination and Cost Control",
    text: "MS Project, tender documentation, BOQs, RFQs, quote comparison, contractor invoice review, quantity statement verification, contractor and supplier coordination, cost tracking, site progress tracking, permitting support, construction documentation, project close-out.",
  },
  {
    label: "Software",
    text: "Excel, Microsoft Suite, AutoCAD, Vectorworks, ArchiCAD, Adobe Creative Suite, Rhino, Grasshopper, 3ds Max, Figma.",
  },
  {
    label: "Languages",
    text: "Italian native | English B2/C1 | German A1/A2 in progress",
  },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Curriculum vitae — Francesca Caslini</title>
    <meta name="description" content="Curriculum vitae di Francesca Caslini, MSc Arch. PoliMi: formazione, esperienze professionali e didattiche, ricerca, tesi, competenze." />
  </head>
  <body>
    <main>
      <div class="cv container">
        <aside class="cv__profile">
          <Image class="cv__photo" src={cvPortrait} alt="Ritratto di Francesca Caslini" width={240} height={290} />
          <div class="cv__identity">
            <p class="cv__name">Francesca Caslini</p>
            <p class="cv__role">MSc Arch. PoliMi</p>
          </div>
          <div class="cv__contact">
            <p>+39 3337438860</p>
            <p><a href="mailto:francesca.caslini@gmail.com">francesca.caslini@gmail.com</a></p>
            <p>Via Sott Paré 8, Bregaglia GR (CH)</p>
          </div>
          <img
            class="cv__signature"
            src={withBase("/assets/images/signature.png")}
            alt="Firma di Francesca Caslini"
            width="870"
            height="286"
          />
        </aside>

        <div class="cv__content">
          {sections.map((section) => (
            <section class="cv-section">
              <h2 class="cv-section__title">{section.title}</h2>
              <ul class="cv-entries">
                {section.entries.map((entry) => (
                  <li class="cv-entry">
                    <div class="cv-entry__meta">
                      {entry.location && <p class="cv-entry__location">{entry.location}</p>}
                      <p class="cv-entry__date">{entry.date}</p>
                    </div>
                    <div class="cv-entry__body">
                      <p class="cv-entry__role">{entry.role}</p>
                      {entry.company && <p class="cv-entry__company">{entry.company}</p>}
                      {entry.note && <p class="cv-entry__note">{entry.note}</p>}
                      {entry.intro && <p class="cv-entry__intro">{entry.intro}</p>}
                      {entry.bullets && entry.bullets.length > 0 && (
                        <ul class="cv-entry__bullets">
                          {entry.bullets.map((bullet) => (
                            <li>
                              {bullet.label && <strong>{bullet.label}</strong>}
                              {bullet.label && ": "}
                              {bullet.text}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          ))}

          <section class="cv-section">
            <h2 class="cv-section__title">Skills</h2>
            <ul class="cv-list">
              {skills.map((skill) => (
                <li>
                  {skill.label && <strong>{skill.label}</strong>}
                  {skill.label && ": "}
                  {skill.text}
                </li>
              ))}
            </ul>
          </section>
        </div>

        <SiteNav class="cv__nav" />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .cv {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding: var(--space-7) var(--space-3);
  }

  .cv__profile {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .cv__photo {
    width: 100%;
    max-width: 15rem;
    height: auto;
    aspect-ratio: 240 / 290;
    object-fit: cover;
  }

  .cv__name {
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .cv__role,
  .cv__contact p {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .cv__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .cv__contact a:hover {
    color: var(--color-blue);
  }

  .cv__signature {
    width: 8rem;
    height: auto;
  }

  .cv__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cv-section__title {
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-grey);
  }

  .cv-entries {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cv-entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-grey);
  }

  .cv-entry:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .cv-entry__meta {
    display: flex;
    flex-direction: column;
  }

  .cv-entry__location,
  .cv-entry__date {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    font-style: italic;
  }

  .cv-entry__body p,
  .cv-entry__bullets {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    line-height: var(--line-height-base);
  }

  .cv-entry__role {
    font-weight: var(--font-weight-book);
  }

  .cv-entry__company {
    font-style: italic;
  }

  .cv-entry__note {
    color: var(--color-blue);
  }

  .cv-entry__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cv-entry__bullets {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-left: var(--space-3);
  }

  .cv-entry__bullets li {
    position: relative;
  }

  .cv-entry__bullets li::before {
    content: "-";
    position: absolute;
    left: calc(-1 * var(--space-2));
  }

  .cv-list {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    line-height: var(--line-height-base);
  }

  @media (min-width: 40rem) {
    .cv-entry {
      flex-direction: row;
      gap: var(--space-4);
    }

    .cv-entry__meta {
      min-width: 10rem;
      flex-shrink: 0;
    }
  }

  @media (min-width: 64rem) {
    .cv {
      grid-template-columns: 1fr 2fr 1fr;
      align-items: start;
    }

    .cv__profile {
      position: sticky;
      top: var(--space-3);
    }
  }
</style>
