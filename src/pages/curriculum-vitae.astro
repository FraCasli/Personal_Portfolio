      {
        date: "Aug 2019",
        role: "Participation to the workshop Cortona Open 3D",
        lines: ["Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI", "Gianluca Emilio Ennio Vita"],
