---
import { Image } from "astro:assets";
import "../styles/main.css";
import TopBar from "../components/TopBar.astro";
import SiteNav from "../components/SiteNav.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../utils/url";
import cvPortrait from "../assets/images/cv-portrait.jpg";

interface CvEntry {
  date: string;
  role?: string;
  lines: string[];
}

interface CvSection {
  title: string;
  entries: CvEntry[];
}

const sections: CvSection[] = [
  {
    title: "Education and training",
    entries: [
      {
        date: "Sep 2020 - May 2023",
        role: "Master Degree in Architecture - Built Environment – Interiors",
        lines: [
          "Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI",
          "Final mark obtained: 110 cum laude /100   Average: 29.37 / 30",
        ],
      },
      {
        date: "Dec 2020 - Feb 2023",
        role: "ASP - Alta Scuola Politecnica",
        lines: [
          "Multidisciplinary international honour program",
          "Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI",
          "Politecnico di Torino - Corso Duca degli Abruzzi, 24, 10129 Torino TO",
        ],
      },
      {
        date: "Sep 2021 - Feb 2022",
        role: "Erasmus+ Programme",
        lines: ["Manchester School of Architecture - Manchester Technology Centre, Oxford Rd, Manchester M1 7ED, United Kingdom"],
      },
      {
        date: "Sep 2017 - Sep 2020",
        role: "Bachelor degree in Architectural design",
        lines: [
          "Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI",
          "Final mark obtained: 110 cum laude /100   Average: 29.1 / 30",
        ],
      },
      {
        date: "Sept 2011 - Jul 2016",
        role: "High School Diploma",
        lines: ["Scientific Lyceum - Filippo Lussana - Via Angelo Maj, 1, 24121 Bergamo BG", "Final mark obtained: 80 / 100"],
      },
    ],
  },
  {
    title: "Professional experience",
    entries: [
      {
        date: "Jan 2024 - Mar 2024",
        role: "Ruinelli Associati Architetti — Architect",
        lines: [
          "Giümella 3, 7610 Soglio CH",
          "Project: Competition for a New School in Maloja, Bregaglia, Switzerland. In collaboration with Bernardo Bader Architekten - Klostergasse 9a, 6900 Bregenz, Austria.",
        ],
      },
      {
        date: "Jan 2023 - Jul 2023",
        role: "Ruinelli Associati Architetti — Architectural Intern",
        lines: [
          "Giümella 3, 7610 Soglio CH",
          "Projects: Design of a detached house in Maloja (GR), starting with the first drafts. Design of a house on the island of Crete. Requalification and conversion of a private house with an attached barn, in Stampa (GR). Preliminary study for the construction of a new square and the municipal building in Talamona (SO).",
        ],
      },
      {
        date: "Oct 2023 - Dec 2023",
        role: "Officina Magisafi - Collaboration",
        lines: ["Via Cinque Martiri, 1, 24029 Vertova BG", "Project: Requalification and conversion of a shed, Monte Cavlera, BG"],
      },
      {
        date: "May 2022 - Jun 2022",
        role: "Studio A/C - Alessia Pessano, Chiara Novello — Curricular Internship",
        lines: ["Via Cellini 6, 20129 Milano MI"],
      },
      {
        date: "Oct 2019 - Nov 2019",
        role: "02 Arch - Ettore Bergamasco, Andrea Starr Stabile — Curricular Internship",
        lines: ["Via Andrea Appiani 3, 20121 Milano MI"],
      },
    ],
  },
  {
    title: "Didactic experiences",
    entries: [
      {
        date: "Sep 2023 - ongoing",
        role: "Didactic Collaboration — Course: Laboratorio di Progettazione Architettonica",
        lines: [
          "Bachelor degree in Architectural design - I year of study",
          "Professors: Bovati Marco, Casonato Camilla",
          "Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI",
        ],
      },
      {
        date: "Sep 2022 - Nov 2023",
        role: "Didactic Collaboration — Course: Fondamenti della Rappresentazione",
        lines: ["Bachelor degree in Architectural design - I year of study", "Professor: Villa Daniele", "Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI"],
      },
      {
        date: "Sep 2021 - Nov 2022",
        role: "Didactic Collaboration — Course: Fondamenti della Rappresentazione",
        lines: ["Bachelor degree in Architectural design - I year of study", "Professor: Villa Daniele", "Politecnico di Milano - Piazza Leonardo da Vinci, 32 20133 Milano MI"],
      },
    ],
  },
  {
    title: "Participations to research",
    entries: [
      {
        date: "Feb 2020 - May 2020",
        role: "Quarantined house-lives. A biography",
        lines: [
          "An exploration of house-lives biographies in quarantined times, through the works of bachelor students from Politecnico di Milano.",
          "Professors: Gennaro Postiglione, Paola Giuseppina Briata, Giovanni Hänninen",
          "Other participants - Students of the course Final design workshop - Bachelor degree in Architectural design - III years of study",
        ],
      },
    ],
  },
  {
    title: "Graduation thesis",
    entries: [
      {
        date: "May 2023",
        role: "Master Thesis",
        lines: ["A dialogue between nature and human sign at high altitude. The project for three bivouacs in the Dolomites.", "Professors: Marco Bovati, Daniele Villa"],
