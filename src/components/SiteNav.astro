---
import { getCollection } from "astro:content";
import { projects } from "../data/projects";
import { withBase } from "../utils/url";

interface Props {
  class?: string;
}
const { class: className } = Astro.props;

const builtSlugs = new Set((await getCollection("projects")).map((entry) => entry.slug));

const linkFor = (slug: string) => withBase(builtSlugs.has(slug) ? `/projects/${slug}/` : `/#${slug}`);

const professionalProjects = projects.filter((p) => p.category === "professional");
const universityProjects = projects.filter((p) => p.category === "university");

const toggleId = `site-nav-toggle-${Math.random().toString(36).slice(2, 9)}`;
---

<nav class:list={["site-nav", className]} aria-label="Sezioni del portfolio">
  <input type="checkbox" id={toggleId} class="site-nav__toggle-input" />
  <label for={toggleId} class="site-nav__toggle-label" aria-label="Apri il menu">
    <span class="site-nav__toggle-icon" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
  </label>

  <ul class="site-nav__list">
    <li><a href={withBase("/")}>Home</a></li>
    <li>
      <details>
        <summary>Professional projects</summary>
        <ul>
          {professionalProjects.map((project) => (
            <li><a href={linkFor(project.slug)}>{project.code}</a></li>
          ))}
        </ul>
      </details>
    </li>
    <li>
      <details>
        <summary>University projects</summary>
        <ul>
          {universityProjects.map((project) => (
            <li><a href={linkFor(project.slug)}>{project.code}</a></li>
          ))}
        </ul>
      </details>
    </li>
    <li><a href={withBase("/curriculum-vitae/")}>Curriculum vitae</a></li>
  </ul>
</nav>

<style>
  .site-nav {
    position: fixed;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 50;
    min-width: 0;
    max-width: calc(100% - 2 * var(--space-3));
  }

  .site-nav ul.site-nav__list {
    background-color: var(--color-bg);
    padding: var(--space-2);
    border: 1px solid var(--color-grey);
  }

  .site-nav__toggle-input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .site-nav__toggle-label {
    display: none;
  }

  .site-nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .site-nav > ul > li > a,
  .site-nav summary {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
    cursor: pointer;
  }

  .site-nav summary {
    list-style: none;
  }

  .site-nav summary::-webkit-details-marker {
    display: none;
  }

  .site-nav summary::after {
    content: "";
    display: inline-block;
    margin-left: var(--space-1);
    width: 0.5em;
    height: 0.5em;
    border-right: 1px solid currentColor;
    border-bottom: 1px solid currentColor;
    transform: rotate(45deg);
    transition: transform 0.15s ease;
  }

  .site-nav details[open] summary::after {
    transform: rotate(-135deg);
  }

  .site-nav details ul {
    margin-top: var(--space-2);
    padding-left: var(--space-3);
    gap: var(--space-1);
  }

  .site-nav a:hover,
  .site-nav summary:hover {
    color: var(--color-blue);
  }

  @media (max-width: 63.9375rem) {
    .site-nav__toggle-label {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 50%;
      background-color: var(--color-black);
      cursor: pointer;
    }

    .site-nav__toggle-input:focus-visible + .site-nav__toggle-label {
      outline: 2px solid var(--color-blue);
      outline-offset: 2px;
    }

    .site-nav__toggle-icon {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .site-nav__toggle-icon span {
      display: block;
      width: 1.1rem;
      height: 2px;
      background-color: var(--color-white);
    }

    .site-nav ul.site-nav__list {
      display: none;
      position: absolute;
      top: calc(100% + var(--space-1));
      right: 0;
      min-width: 12rem;
    }

    .site-nav__toggle-input:checked ~ .site-nav__list {
      display: flex;
    }
  }
</style>
