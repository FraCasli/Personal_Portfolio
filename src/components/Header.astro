---
import SiteNav from "./SiteNav.astro";
import { withBase } from "../utils/url";
---

<header class="hero-content">
  <div class="hero__top">
    <div class="hero__top-right">
      <div class="hero__identity">
        <p class="hero__name">Francesca Caslini</p>
        <p class="hero__role">MSc Arch. PoliMi</p>
        <img
          class="hero__signature"
          src={withBase("/assets/images/signature.png")}
          alt="Firma di Francesca Caslini"
          width="870"
          height="286"
        />
      </div>

      <SiteNav class="hero__nav" />
    </div>
  </div>

  <div class="hero__title-block">
    <h1 class="hero__title">Architecture portfolio</h1>
    <p class="hero__hint">
      Go to the selected projects
      <span class="hero__arrows" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
    </p>
  </div>
</header>

<style>
  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-3) var(--space-3) var(--space-6);
  }

  .hero__top {
    display: flex;
    justify-content: flex-end;
    padding-right: 3.5rem;
  }

  .hero__top-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
    min-width: 0;
    max-width: 100%;
  }

  .hero__identity {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
    text-align: right;
    color: var(--color-text);
    min-width: 0;
  }

  .hero__name {
    font-weight: var(--font-weight-book);
    font-size: clamp(1rem, 4.5vw, var(--font-size-md));
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .hero__role {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
  }

  .hero__signature {
    width: 8rem;
    height: auto;
    margin-top: var(--space-1);
  }

  .hero__title-block {
    min-width: 0;
    max-width: 100%;
    text-align: left;
    color: var(--color-text);
  }

  .hero__title {
    font-weight: var(--font-weight-book);
    font-size: clamp(1.5rem, 6vw, var(--font-size-xl));
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    line-height: var(--line-height-tight);
  }

  .hero__hint {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-top: var(--space-3);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
  }

  .hero__arrows {
    display: inline-flex;
    gap: 0.2em;
  }

  .hero__arrows span {
    width: 0;
    height: 0;
    border-top: 0.3em solid transparent;
    border-bottom: 0.3em solid transparent;
    border-left: 0.35em solid var(--color-text);
  }

  @media (min-width: 40rem) {
    .hero__signature {
      width: 10rem;
    }
  }

  @media (min-width: 64rem) {
    .hero-content {
      min-height: 100vh;
      padding: var(--space-4) var(--space-4) var(--space-9);
    }

    .hero__top {
      padding-right: 14rem;
    }

    .hero__title-block {
      margin-top: auto;
    }
  }
</style>
