---
import { Image } from "astro:assets";
import TopBar from "./TopBar.astro";
import SiteNav from "./SiteNav.astro";
import { withBase } from "../utils/url";
import heroMountain from "../assets/images/hero-mountain.jpg";
---

<header class="site-header">
  <TopBar />

  <div class="hero">
    <Image
      class="hero__bg"
      src={heroMountain}
      alt="Cresta innevata al tramonto"
      widths={[640, 960, 1440, 1920]}
      sizes="100vw"
      priority
    />

    <div class="hero__overlay container">
      <div class="hero__top">
        <div class="hero__top-right">
          <div class="hero__identity">
            <p class="hero__name">Francesca Caslini</p>
            <p class="hero__role">MSc Arch. PoliMi</p>
            <img
              class="hero__signature"
              src={withBase("/assets/images/signature.png")}
              alt="Firma di Francesca Caslini"
              width="870"
              height="286"
            />
          </div>

          <SiteNav class="hero__nav" />
        </div>
      </div>

      <div class="hero__title-block">
        <h1 class="hero__title">Architecture<br />portfolio</h1>
        <p class="hero__hint">Scroll to see the selected projects</p>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-bg);
  }

  .hero {
    position: relative;
    aspect-ratio: 1920 / 1034;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3);
  }

  .hero__top {
    display: flex;
    justify-content: flex-end;
  }

  .hero__top-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
  }

  .hero__identity {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
    text-align: right;
    color: var(--color-gold);
  }

  .hero__name {
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-md);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .hero__role {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
  }

  .hero__signature {
    width: 8rem;
    height: auto;
    margin-top: var(--space-1);
  }

  .hero__title-block {
    align-self: flex-end;
    text-align: right;
    color: var(--color-gold);
  }

  .hero__title {
    font-weight: var(--font-weight-book);
    font-size: var(--font-size-xl);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    line-height: var(--line-height-tight);
  }

  .hero__hint {
    margin-top: var(--space-3);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
  }

  @media (min-width: 40rem) {
    .hero__signature {
      width: 10rem;
    }
  }
</style>
