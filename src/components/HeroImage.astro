---
import { Image } from "astro:assets";
import heroMountain from "../assets/images/hero-mountain.jpg";
---

<div class="hero-image">
  <Image
    class="hero-image__bg"
    src={heroMountain}
    alt="Cresta innevata al tramonto"
    widths={[320, 480, 640, 960, 1200]}
    sizes="(min-width: 64rem) 25vw, 100vw"
    priority
  />
</div>

<style>
  .hero-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    flex-shrink: 0;
  }

  .hero-image__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 64rem) {
    .hero-image {
      aspect-ratio: auto;
      grid-column: 1;
      align-self: start;
      position: sticky;
      top: 0;
      height: 100vh;
    }
  }
</style>
