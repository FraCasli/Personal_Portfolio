---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { projects } from "../data/projects";
import { withBase } from "../utils/url";
import thumbGarniBarPost from "../assets/images/projects/ristorante-garni-bar-post/01-exterior.jpg";
import thumbStallaMontaccio from "../assets/images/projects/stalla-montaccio/01-interior-kitchen.png";
import thumbCasaSb from "../assets/images/projects/thumb-casa-sb.png";
import thumbVersoSud from "../assets/images/projects/thumb-verso-sud.png";
import thumbCasaLn from "../assets/images/projects/thumb-casa-ln.jpeg";
import thumbStudentHostel from "../assets/images/projects/thumb-student-hostel.png";
import thumbDiffusedHouse from "../assets/images/projects/thumb-diffused-house.png";
import thumbSchoolRubattino from "../assets/images/projects/thumb-school-rubattino.png";
import thumbHedgehog1 from "../assets/images/projects/thumb-hedgehog-1.png";
import thumbColonie from "../assets/images/projects/thumb-colonie.png";

const thumbnails: Record<string, { src: ImageMetadata; alt: string }[]> = {
  "ristorante-garni-bar-post": [{ src: thumbGarniBarPost, alt: "Ristorante Garni Bar Post, Castasegna" }],
  "stalla-montaccio": [{ src: thumbStallaMontaccio, alt: "Stalla Montaccio, Montaccio" }],
  "casa-sb": [{ src: thumbCasaSb, alt: "Casa SB, Maloja" }],
  "verso-sud": [{ src: thumbVersoSud, alt: "Verso Sud, Crete" }],
  "casa-ln": [{ src: thumbCasaLn, alt: "Casa LN, Stampa" }],
  "student-hostel": [{ src: thumbStudentHostel, alt: "Student hostel, Milano" }],
  "diffused-house": [{ src: thumbDiffusedHouse, alt: "Diffused house, Monesteroli" }],
  "school-rubattino": [{ src: thumbSchoolRubattino, alt: "A school for Rubattino, Milano" }],
  hedgehog: [{ src: thumbHedgehog1, alt: "Hedgehog, Milano" }],
  colonie: [{ src: thumbColonie, alt: "Colonie, Milano" }],
};

const builtSlugs = new Set((await getCollection("projects")).map((entry) => entry.slug));
---

<section id="projects" class="project-list" aria-label="Progetti selezionati">
  <ul>
    {projects.map((project) => {
      const isBuilt = builtSlugs.has(project.slug);
      const Tag = isBuilt ? "a" : "div";
      return (
        <li id={project.slug}>
          <Tag class="project-row" href={isBuilt ? withBase(`/projects/${project.slug}/`) : undefined}>
            <p class="project-row__code">{project.code}</p>
            <p class="project-row__meta">
              {project.location}<br />{project.type}
            </p>
            <p class="project-row__meta">
              {project.year}<br />{project.studio}
            </p>
            <div class="project-row__thumbs">
              {thumbnails[project.slug].map((image) => (
                <Image
                  src={image.src}
                  alt={image.alt}
                  width={160}
                  height={88}
                  class="project-row__thumb"
                />
              ))}
            </div>
          </Tag>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .project-list {
    display: grid;
    grid-template-columns: 1fr;
    padding: 0 var(--space-3) var(--space-7);
  }

  /* Extra breathing room before the first project row on mobile, on top
     of the hero-content bottom padding, so the list doesn't crowd the
     hero's title/hint right after the first scroll. */
  @media (max-width: 63.99rem) {
    .project-list {
      padding-top: var(--space-6);
    }
  }

  .project-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding-block: var(--space-4);
    border-bottom: 1px solid var(--color-grey);
  }

  .project-row:focus-visible {
    outline: 2px solid var(--color-blue);
    outline-offset: 2px;
  }

  .project-row__code,
  .project-row__meta {
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-sm);
    letter-spacing: var(--tracking-base);
  }

  .project-row__thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .project-row__thumb {
    width: min(var(--size-thumb), 40vw);
    height: auto;
    aspect-ratio: 160 / 88;
    object-fit: cover;
    transition: opacity var(--transition-base);
  }

  /* Dim-until-hover only makes sense where hover exists; touch devices
     always see full-opacity thumbnails instead of a permanently faded row. */
  @media (hover: hover) and (pointer: fine) {
    .project-row__thumb {
      opacity: var(--opacity-dim);
    }

    .project-row:hover .project-row__thumb,
    .project-row:focus-within .project-row__thumb {
      opacity: 1;
    }
  }

  @media (min-width: 64rem) {
    .project-row {
      grid-template-columns: 1fr 1fr 1fr auto;
      align-items: center;
    }
  }
</style>
